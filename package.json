{
  "name": "jurni",
  "version": "0.1.0",
  "description": "A dashboard for your life. Local-first, AI-powered, open source.",
  "author": {
    "name": "Everest Minds for Programming",
    "email": "behairy@everestminds.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/everestminds/jurni",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/everestminds/jurni.git"
  },
  "bugs": {
    "url": "https://github.com/everestminds/jurni/issues"
  },
  "keywords": [
    "personal-dashboard",
    "life-tracking",
    "local-first",
    "electron",
    "ai",
    "llm",
    "journaling",
    "self-quantification"
  ],
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "vite build && electron .",
    "build": "vite build && electron-builder",
    "release": "vite build && electron-builder --publish always",
    "release:dry": "vite build && electron-builder --publish never",
    "rebuild": "npx @electron/rebuild",
    "reset": "rm -rf ~/.jurni/jurni.db && echo 'Database wiped'",
    "logs": "tail -f ~/.jurni/crawler.log"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.0",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "exifr": "^7.1.3",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.jurni.app",
    "productName": "Jurni",
    "artifactName": "Jurni-${version}-${arch}.${ext}",
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.lifestyle",
      "icon": "electron/assets/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/assets/entitlements.mac.plist",
      "entitlementsInherit": "electron/assets/entitlements.mac.plist",
      "notarize": {
        "teamId": "U2EBW657CK"
      }
    },
    "dmg": {
      "sign": false
    },
    "publish": {
      "provider": "github",
      "owner": "everestminds",
      "repo": "jurni",
      "releaseType": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "database/**/*",
      "channels/**/*",
      "processing/**/*",
      "scoring/**/*"
    ]
  }
}
