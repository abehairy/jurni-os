{
  "name": "jurni",
  "version": "0.1.0",
  "description": "Your life has patterns you can't see. Jurni sees them.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "start": "vite build && electron .",
    "build": "vite build && electron-builder",
    "rebuild": "npx @electron/rebuild",
    "reset": "rm -rf ~/.jurni/jurni.db && echo 'Database wiped'",
    "logs": "tail -f ~/.jurni/crawler.log"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.0",
    "date-fns": "^4.1.0",
    "exifr": "^7.1.3",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.jurni.app",
    "productName": "Jurni",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.lifestyle"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "database/**/*",
      "channels/**/*",
      "processing/**/*",
      "scoring/**/*"
    ]
  }
}
