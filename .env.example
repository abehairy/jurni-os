# Copy this file to .env and fill in the values before running `npm run release`.
# Never commit .env — it's gitignored. These are only needed at release time.

# ── Apple signing + notarization ─────────────────────────────────────────────
# Your Apple Developer Team ID (10-char alphanumeric).
# Find at https://developer.apple.com/account → Membership Details → Team ID.
APPLE_TEAM_ID=

# The Apple ID email tied to your developer account.
APPLE_ID=

# App-specific password for notarization (NOT your real Apple password).
# Generate at https://account.apple.com → Sign-In & Security → App-Specific Passwords.
APPLE_APP_SPECIFIC_PASSWORD=

# ── GitHub publish (electron-updater update feed) ────────────────────────────
# Personal access token with `repo` scope (for private repos) or `public_repo`
# scope (for public repos). Used by electron-builder to upload release assets.
# Create at https://github.com/settings/tokens.
GH_TOKEN=

# ── Optional: local signing via .p12 (if you keychain-free sign on CI) ───────
# Path to the Developer ID Application .p12 certificate export.
# CSC_LINK=

# Password for the .p12 file.
# CSC_KEY_PASSWORD=
